{
  "model": "haiku",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "List(*)",
      "Read(**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test *)",
      "Bash(bundle exec rspec *)",
      "Bash(bundle exec rubocop *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Write(*.env)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(.env*)",
      "Write(**/*.env)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/.env*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * --force)",
      "Bash(git push * -f)",
      "Bash(git reset --hard *)",
      "Bash(git filter-branch *)",
      "Bash(git reflog delete *)",
      "Bash(*rails db:drop*)",
      "Bash(*rails db:reset*)",
      "Bash(*rails c production*)",
      "Bash(*RAILS_ENV=production*)",
      "Bash(psql * -c \"DROP *\")",
      "Bash(psql * -c \"TRUNCATE *\")",
      "Bash(redis-cli FLUSHALL)",
      "Bash(redis-cli FLUSHDB)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(docker rm *)",
      "Bash(docker system prune *)",
      "Bash(mise uninstall *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*.env)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(**/.env*)",
      "Read(**/*.env)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}
